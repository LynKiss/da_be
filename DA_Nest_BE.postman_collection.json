      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('username', `user_${suffix}`);",
                  "pm.collectionVariables.set('email', `user_${suffix}@example.com`);",
                  "pm.collectionVariables.set('password', 'Secret123');",
                  "pm.collectionVariables.set('newPassword', 'Secret1234');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Register response envelope is valid', function () {",
                  "  pm.expect(json).to.have.property('statusCode');",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data.username).to.eql(pm.collectionVariables.get('username'));",
                  "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('email'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"avatarUrl\": \"https://example.com/avatars/{{username}}.jpg\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        },
